PORT=3000
# Use localhost when running the app directly on your machine (e.g. Laragon).
MONGODB_URL=mongodb://localhost:27017/fullstack-blog
# Docker: use `docker compose up --build` (see docker-compose.yml), or for a one-off
# `docker run` against host MongoDB on Windows/Mac:
# MONGODB_URL=mongodb://host.docker.internal:27017/fullstack-blog
SESSION_SECRET=replace-with-a-long-random-secret
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
